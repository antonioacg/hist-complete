#!/usr/bin/env python3
"""PTY wrapper that translates escape sequences before fzf sees them.

Uses pty.fork() which calls forkpty() internally — handles controlling
terminal setup correctly on macOS (unlike Go's SysProcAttr.Ctty).

The child gets the slave pty as its controlling terminal (/dev/tty).
The parent relays between the real terminal and the master pty,
translating sequences in the input direction.

stdin/stdout are preserved for fzf-tab piping (candidates in, selection out).
Only /dev/tty (user interaction) goes through the pty with translation.
"""

import os
import select
import signal
import struct
import sys
import termios
import tty
import fcntl

TRANSLATIONS = {
    b"\x1b[13;2u": b"\x0f",  # Shift+Enter (CSI u) -> Ctrl+O
}

TIOCSWINSZ = 0x80087467 if sys.platform == "darwin" else termios.TIOCSWINSZ
TIOCGWINSZ = 0x40087468 if sys.platform == "darwin" else termios.TIOCGWINSZ


def get_winsize(fd):
    try:
        result = fcntl.ioctl(fd, TIOCGWINSZ, b"\x00" * 8)
        return struct.unpack("HHHH", result)[:2]  # rows, cols
    except OSError:
        return 24, 80


def set_winsize(fd, rows, cols):
    try:
        fcntl.ioctl(fd, TIOCSWINSZ, struct.pack("HHHH", rows, cols, 0, 0))
    except OSError:
        pass


def translate(data):
    """Translate known sequences in data, return (output, pending)."""
    out = bytearray()
    i = 0
    while i < len(data):
        matched = False
        for seq, replacement in TRANSLATIONS.items():
            if data[i:].startswith(seq):
                out.extend(replacement)
                i += len(seq)
                matched = True
                break
            if seq.startswith(data[i:]) and len(data[i:]) < len(seq):
                # Partial match — return pending bytes
                return bytes(out), data[i:]
        if not matched:
            out.append(data[i])
            i += 1
    return bytes(out), b""


def main():
    fzf_bin = os.environ.get("FZF_KEY_TRANSLATE_CMD", "fzf")
    argv = [fzf_bin] + sys.argv[1:]

    # Save original stdin/stdout fds (fzf-tab pipes)
    saved_stdin = os.dup(0)
    saved_stdout = os.dup(1)

    # Open real terminal BEFORE fork
    tty_fd = os.open("/dev/tty", os.O_RDWR)

    # pty.fork() calls forkpty() — correctly sets controlling terminal on macOS
    import pty as pty_mod
    pid, master_fd = pty_mod.fork()

    if pid == 0:
        # Child: slave pty is now our controlling terminal (/dev/tty).
        # Restore stdin/stdout to the original pipes for fzf-tab.
        os.dup2(saved_stdin, 0)
        os.dup2(saved_stdout, 1)
        os.close(saved_stdin)
        os.close(saved_stdout)
        os.close(tty_fd)
        os.execvp(argv[0], argv)
        sys.exit(1)

    # Parent: relay between real terminal and master pty
    os.close(saved_stdin)
    os.close(saved_stdout)

    # Raw mode on real terminal
    old_attrs = termios.tcgetattr(tty_fd)
    tty.setraw(tty_fd)

    # Sync terminal size
    rows, cols = get_winsize(tty_fd)
    set_winsize(master_fd, rows, cols)

    def handle_winch(*_):
        r, c = get_winsize(tty_fd)
        set_winsize(master_fd, r, c)

    signal.signal(signal.SIGWINCH, handle_winch)

    pending = b""
    try:
        while True:
            try:
                rlist, _, _ = select.select([master_fd, tty_fd], [], [], 0.1)
            except (select.error, OSError):
                break

            # pty master -> real terminal (fzf UI output)
            if master_fd in rlist:
                try:
                    data = os.read(master_fd, 4096)
                except OSError:
                    break
                if not data:
                    break
                os.write(tty_fd, data)

            # real terminal -> pty master (translated user input)
            if tty_fd in rlist:
                try:
                    data = os.read(tty_fd, 4096)
                except OSError:
                    break
                if not data:
                    break
                out, pending = translate(pending + data)
                if out:
                    os.write(master_fd, out)

            # Check if child exited
            result = os.waitpid(pid, os.WNOHANG)
            if result[0] != 0:
                # Drain remaining pty output
                try:
                    while True:
                        rlist, _, _ = select.select([master_fd], [], [], 0.01)
                        if not rlist:
                            break
                        data = os.read(master_fd, 4096)
                        if not data:
                            break
                        os.write(tty_fd, data)
                except OSError:
                    pass
                termios.tcsetattr(tty_fd, termios.TCSAFLUSH, old_attrs)
                os.close(tty_fd)
                os.close(master_fd)
                sys.exit(os.waitstatus_to_exitcode(result[1]))

    except KeyboardInterrupt:
        pass
    finally:
        termios.tcsetattr(tty_fd, termios.TCSAFLUSH, old_attrs)
        os.close(tty_fd)
        os.close(master_fd)

    _, status = os.waitpid(pid, 0)
    sys.exit(os.waitstatus_to_exitcode(status))


if __name__ == "__main__":
    main()
